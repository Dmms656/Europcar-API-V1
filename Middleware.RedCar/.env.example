# =====================================================
# Middleware.RedCar - Variables de entorno
# =====================================================
# Copia este archivo a Middleware.RedCar/.env y rellena los valores.
# El .env real esta cubierto por el patron ".env" del .gitignore del repo raiz.
# =====================================================

# --- URLs de los microservicios RedCar V2 ---
# En dev local, cada MS corre en su puerto del 5101 al 5105 (ver EUROPCAR_V2/README.md).
# En produccion (Render, etc.) reemplazar por la URL publica de cada MS.
Microservicios__Seguridad__BaseUrl=http://localhost:5101
Microservicios__Catalogo__BaseUrl=http://localhost:5102
Microservicios__Localizaciones__BaseUrl=http://localhost:5103
Microservicios__Clientes__BaseUrl=http://localhost:5104
Microservicios__Reservas__BaseUrl=http://localhost:5105

# Timeouts y reintentos por cliente HTTP (segundos)
Microservicios__Seguridad__TimeoutSeconds=10
Microservicios__Catalogo__TimeoutSeconds=10
Microservicios__Localizaciones__TimeoutSeconds=10
Microservicios__Clientes__TimeoutSeconds=10
Microservicios__Reservas__TimeoutSeconds=30

# --- JWT (debe ser el MISMO SecretKey que usan los MS) ---
JWT__SecretKey="redcar-v2-dev-jwt-secret-cambiar-en-prod-min-32b"
JWT__Issuer="redcar-v2"
JWT__Audience="redcar-v2-clients"
JWT__ExpirationMinutes=60

# --- IVA aplicado a las reservas (porcentaje) ---
Negocio__IvaPorcentaje=15
