  "Integration": {
    "UseGraphQl": false,
    "EmbeddedGraphQl": true,
    "GraphQlBaseUrl": "http://127.0.0.1:8080/graphql"
  },
  "EvB": {
    "Enabled": false,
    "SagaTimeoutSeconds": 90
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/redcar-marketplace",
    "Username": "redcar",
    "Password": "redcar_dev"
