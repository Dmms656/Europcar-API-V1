{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": false
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:8081",
      "https://localhost:8081",
      "http://127.0.0.1:8081",
      "https://europcar-frontend.onrender.com"
    ]
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "redcar-v2",
    "Audience": "redcar-v2-clients",
    "ExpirationMinutes": 60
  },
  "Negocio": {
    "IvaPorcentaje": 15,
    "OrigenCanalReserva": "BOOKING"
  },
  "Microservicios": {
    "Catalogo":       { "BaseUrl": "http://localhost:5102", "TimeoutSeconds": 60 },
    "Localizaciones": { "BaseUrl": "http://localhost:5103", "TimeoutSeconds": 60 },
    "Clientes":       { "BaseUrl": "http://localhost:5104", "TimeoutSeconds": 60 },
    "Reservas":       { "BaseUrl": "http://localhost:5105", "TimeoutSeconds": 90 }
