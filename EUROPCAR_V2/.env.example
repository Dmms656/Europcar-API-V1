# =====================================================
# EUROPCAR_V2 - Variables de entorno para los 5 microservicios
# =====================================================
# Copia este archivo a EUROPCAR_V2/.env y reemplaza los valores.
# El .env real NO se versiona (esta cubierto por la regla ".env"
# del .gitignore raiz).
#
# Cada microservicio lee SU connection string de la variable
# ConnectionStrings__Default a traves de appsettings + DOTNET env override.
# Por convencion ASP.NET Core: "ConnectionStrings__Default" -> ConnectionStrings:Default
# =====================================================

# --- Datos del proyecto Supabase ---
SUPABASE_PROJECT_REF=olmokxntknfermhuwrwc
SUPABASE_REGION=us-east-1
SUPABASE_POOLER_HOST=aws-1-us-east-1.pooler.supabase.com

# --- Passwords de los roles ms_* (mismos que en 99_supabase_grants.sql) ---
PASSWORD_SEGURIDAD=<rellena>
PASSWORD_CATALOGO=<rellena>
PASSWORD_LOCALIZACIONES=<rellena>
PASSWORD_CLIENTES=<rellena>
PASSWORD_RESERVAS=<rellena>

# =====================================================
# Connection strings por microservicio (formato Npgsql)
# Importante con transaction pooler (puerto 6543):
#   - Max Auto Prepare=0          (los prepared statements no sobreviven a rotacion de conexiones)
#   - No Reset On Close=true      (evita DISCARD ALL que el pooler no soporta)
#   - Pooling=true                (pool del lado Npgsql; el pooler externo no lo reemplaza)
#   - Multiplexing=false          (no es compatible con el pooler de transaccion)
# =====================================================

ConnectionStrings__Default__Seguridad="Host=aws-1-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_seguridad.olmokxntknfermhuwrwc;Password=<PASSWORD_SEGURIDAD>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10;Multiplexing=false;Max Auto Prepare=0;No Reset On Close=true;Include Error Detail=true;"

ConnectionStrings__Default__Catalogo="Host=aws-1-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_catalogo.olmokxntknfermhuwrwc;Password=<PASSWORD_CATALOGO>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10;Multiplexing=false;Max Auto Prepare=0;No Reset On Close=true;Include Error Detail=true;"

ConnectionStrings__Default__Localizaciones="Host=aws-1-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_localizaciones.olmokxntknfermhuwrwc;Password=<PASSWORD_LOCALIZACIONES>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10;Multiplexing=false;Max Auto Prepare=0;No Reset On Close=true;Include Error Detail=true;"

ConnectionStrings__Default__Clientes="Host=aws-1-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_clientes.olmokxntknfermhuwrwc;Password=<PASSWORD_CLIENTES>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10;Multiplexing=false;Max Auto Prepare=0;No Reset On Close=true;Include Error Detail=true;"

ConnectionStrings__Default__Reservas="Host=aws-1-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_reservas.olmokxntknfermhuwrwc;Password=<PASSWORD_RESERVAS>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10;Multiplexing=false;Max Auto Prepare=0;No Reset On Close=true;Include Error Detail=true;"

# =====================================================
# JWT
# =====================================================
# Para academic/dev usa el mismo secret en todos los MS (SimetricKey).
# En produccion: rotar y guardar en un secret manager (Render env vars, etc.).
JWT__SecretKey="cambia-este-secreto-academico-por-uno-real-de-al-menos-32-bytes"
JWT__Issuer="redcar-v2"
JWT__Audience="redcar-v2-clients"
JWT__ExpirationMinutes=60

# =====================================================
# MS.Reservas: URLs publicas de otros MS (para enriquecer GET reserva / disponibilidad)
# Opcional. Si vacio: disponibilidad solo usa BD reservas; GET reserva sin marcas/nombres remotos.
# En Render: https://catalogo.onrender.com (sin slash final; el codigo lo normaliza)
# =====================================================
Downstream__CatalogoUrl=
Downstream__LocalizacionesUrl=
Downstream__ClientesUrl=

# --- RabbitMQ (Event Bus / MassTransit) ---
RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__VirtualHost=/redcar-marketplace
RabbitMQ__Username=redcar
RabbitMQ__Password=redcar_dev
