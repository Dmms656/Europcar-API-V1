# =====================================================
# Connection strings - Supabase (1 proyecto, 5 schemas, 5 roles)
# =====================================================
# Copia este archivo a .env y reemplaza:
#   - <PROJECT_REF>       el identificador de tu proyecto Supabase (ej. abcdefghijklmnop)
#   - <REGION>            la region del proyecto (ej. us-east-1, sa-east-1)
#                         Ojo: el host del pooler tiene un prefijo numerico que NO siempre
#                         es 0. En proyectos recientes suele ser "aws-1-<region>".
#                         Cogelo exacto de: Project Settings -> Database -> Connection info.
#   - <PASSWORD_*>        las 5 contrasenias que usaste en 99_supabase_grants.sql
#
# NO commitees el .env real. Solo se versiona este .env.example.
# Verifica que .env este ignorado por git en .gitignore.
#
# Formato:  Npgsql connection string (lo entiende .NET / Npgsql directo).
# Pooler:   transaction mode, puerto 6543 (recomendado para APIs stateless).
#           Si necesitas LISTEN/NOTIFY o transacciones largas, usa el direct
#           connection (db.<PROJECT_REF>.supabase.co:5432) o el session pooler
#           (mismo host pero puerto 5432).
# =====================================================

# --- MS.Seguridad (schemas: security, audit) ---
SEGURIDAD_DB_CONNECTION="Host=aws-1-<REGION>.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_seguridad.<PROJECT_REF>;Password=<PASSWORD_SEGURIDAD>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;"

# --- MS.Catalogo (schema: catalogo) ---
CATALOGO_DB_CONNECTION="Host=aws-1-<REGION>.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_catalogo.<PROJECT_REF>;Password=<PASSWORD_CATALOGO>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;"

# --- MS.Localizaciones (schema: localizaciones) ---
LOCALIZACIONES_DB_CONNECTION="Host=aws-1-<REGION>.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_localizaciones.<PROJECT_REF>;Password=<PASSWORD_LOCALIZACIONES>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;"

# --- MS.Clientes (schema: clientes) ---
CLIENTES_DB_CONNECTION="Host=aws-1-<REGION>.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_clientes.<PROJECT_REF>;Password=<PASSWORD_CLIENTES>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;"

# --- MS.Reservas + Facturacion (schema: reservas) ---
RESERVAS_DB_CONNECTION="Host=aws-1-<REGION>.pooler.supabase.com;Port=6543;Database=postgres;Username=ms_reservas.<PROJECT_REF>;Password=<PASSWORD_RESERVAS>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;"


# =====================================================
# Alternativa: formato URL (libpq) por si tu cliente lo prefiere
# =====================================================
# SEGURIDAD_DB_URL="postgresql://ms_seguridad.<PROJECT_REF>:<PASSWORD_SEGURIDAD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require"
# CATALOGO_DB_URL="postgresql://ms_catalogo.<PROJECT_REF>:<PASSWORD_CATALOGO>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require"
# LOCALIZACIONES_DB_URL="postgresql://ms_localizaciones.<PROJECT_REF>:<PASSWORD_LOCALIZACIONES>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require"
# CLIENTES_DB_URL="postgresql://ms_clientes.<PROJECT_REF>:<PASSWORD_CLIENTES>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require"
# RESERVAS_DB_URL="postgresql://ms_reservas.<PROJECT_REF>:<PASSWORD_RESERVAS>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require"
