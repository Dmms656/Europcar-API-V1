# Copia a .env (no versionado) o usa User Secrets (dotnet user-secrets set ...).
# Convención ASP.NET Core: doble guion bajo para secciones anidadas.

ConnectionStrings__RentalDb=Host=YOUR_HOST;Port=5432;Database=postgres;Username=YOUR_USER;Password=YOUR_PASSWORD;Ssl Mode=Require;Trust Server Certificate=true;

JwtSettings__SecretKey=REEMPLAZA_POR_SECRETO_DE_AL_MENOS_32_CARACTERES
JwtSettings__Issuer=Europcar.Rental.Api
JwtSettings__Audience=Europcar.Rental.Client
JwtSettings__ExpirationMinutes=60

# Solo desarrollo: contraseña de usuarios seed (admin.dev, agente.pos, cliente.web)
SEED_DEV_PASSWORD=12345

# Opcional: forzar Swagger fuera de Development
# Swagger__Enabled=true
