# API — desarrollo local (middleware en puerto 5200)
EXPO_PUBLIC_API_URL=http://localhost:5200/api/v1

# API — producción (Render: Environment → EXPO_PUBLIC_API_URL)
# EXPO_PUBLIC_API_URL=https://europcar-api-v2.onrender.com/api/v1

# Cloudinary (futuro — admin vehículos)
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
# EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Red local (Expo Go en dispositivo físico): usa la IP de tu PC
# EXPO_PUBLIC_API_URL=http://192.168.1.X:5200/api/v1
