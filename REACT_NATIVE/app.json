{
  "expo": {
    "name": "Europcar Unificado",
    "slug": "europcar-unified",
    "version": "1.1.3",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b3d6fb80-f42a-4ecb-ab38-26066bee068d"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "europcar",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.europcar.mobile"
    },
    "android": {
      "package": "com.europcar.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f1419",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "apiUrl": "https://europcar-api-v2.onrender.com/api/v1",
      "eas": {
        "projectId": "b3d6fb80-f42a-4ecb-ab38-26066bee068d"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3b82f6"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f1419"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
