# Cloudinary - subida unsigned de imagenes de vehiculos
# Cloud name de la cuenta Cloudinary (visible en el dashboard, esquina superior izquierda).
VITE_CLOUDINARY_CLOUD_NAME=dt4qaly0t

# Upload preset UNSIGNED creado en:
# Cloudinary > Settings > Upload > Upload presets > Add upload preset
# Importante: marcar "Signing Mode = Unsigned" y guardar el "Preset name".
VITE_CLOUDINARY_UPLOAD_PRESET=

# URL base de la API (axiosClient). Debe incluir /api/v1 para booking + rutas relativas del frontend.
# Middleware.RedCar (launchSettings): http://localhost:5200/api/v1
# Monolito legado (_legacy/EuropcarRental), si lo usas para admin/Auth: suele ser http://localhost:5207/api/v1
VITE_API_URL=http://localhost:5200/api/v1
