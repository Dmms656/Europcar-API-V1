# Cloudinary - subida unsigned de imagenes de vehiculos
# Cloud name de la cuenta Cloudinary (visible en el dashboard, esquina superior izquierda).
VITE_CLOUDINARY_CLOUD_NAME=dt4qaly0t

# Upload preset UNSIGNED creado en:
# Cloudinary > Settings > Upload > Upload presets > Add upload preset
# Importante: marcar "Signing Mode = Unsigned" y guardar el "Preset name".
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- API (axios) ---
# Desarrollo con proxy Vite (recomendado): deja VITE_API_URL vacío o comenta la línea.
# El dev server reenvía /api → middleware (ver VITE_DEV_API_PROXY).
# VITE_DEV_API_PROXY=http://localhost:5200
# VITE_DEV_API_PROXY=https://europcar-api-v2.onrender.com

# Desarrollo sin proxy (llamada directa; CORS debe incluir http://localhost:5173):
# VITE_API_URL=http://localhost:5200/api/v1

# Build producción (Render estático): obligatorio, con /api/v1 al final
# VITE_API_URL=https://europcar-api-v2.onrender.com/api/v1
